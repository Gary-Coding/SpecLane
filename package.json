{
  "name": "@gary-coding/spectrace",
  "version": "0.1.7",
  "description": "SpecTrace workflow skill and CLI for demand-driven AI delivery with OpenSpec bridge support.",
  "license": "MIT",
  "author": "Gary-Coding",
  "homepage": "https://github.com/Gary-Coding/spectrace#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gary-Coding/spectrace.git"
  },
  "bugs": {
    "url": "https://github.com/Gary-Coding/spectrace/issues"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "spectrace": "bin/spectrace.js",
    "st": "bin/spectrace.js"
  },
  "files": [
    "bin/",
    "scripts/",
    "!scripts/__pycache__/",
    "!scripts/**/*.pyc",
    "skills/",
    "!skills/**/scripts/__pycache__/",
    "!skills/**/scripts/**/*.pyc",
    "templates/",
    "docs/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md"
  ],
  "scripts": {
    "setup": "python3 scripts/spectrace-setup.py",
    "check": "python3 -m py_compile scripts/spectrace-cli.py scripts/spectrace-setup.py scripts/spectrace-smoke-test.py scripts/spectrace-e2e-test.py skills/spectrace-rd/scripts/*.py",
    "smoke": "python3 scripts/spectrace-smoke-test.py",
    "e2e": "python3 scripts/spectrace-e2e-test.py",
    "pack:check": "npm pack --dry-run"
  },
  "keywords": [
    "ai",
    "workflow",
    "openspec",
    "codex",
    "claude",
    "skill"
  ]
}
